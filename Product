{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "price": {
      "type": "number",
      "description": "Product price in Naira"
    },
    "category": {
      "type": "string",
      "enum": [
        "Home & Kitchen",
        "Fashion",
        "Wellness",
        "Mobility"
      ],
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "image_url": {
      "type": "string",
      "description": "Product image URL"
    },
    "in_stock": {
      "type": "boolean",
      "default": true,
      "description": "Whether product is in stock"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether product is featured on homepage"
    }
  },
  "required": [
    "name",
    "price",
    "category"
  ]
}
